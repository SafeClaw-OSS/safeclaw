{
  "$schema": "./services.schema.json",
  "$comment": "SafeClaw known service catalog. Data file — not compiled into the binary. Used by setup UIs, CLI tools, and documentation.",

  "services": {
    "anthropic": {
      "name": "Anthropic",
      "description": "Claude AI models",
      "category": "ai",
      "upstream": "https://api.anthropic.com",
      "auth": { "type": "header", "header": "x-api-key" },
      "key_placeholder": "sk-ant-api03-…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://docs.anthropic.com",
      "color": "#d4a017"
    },
    "openai": {
      "name": "OpenAI",
      "description": "GPT and o-series models",
      "category": "ai",
      "upstream": "https://api.openai.com",
      "auth": { "type": "header", "header": "Authorization", "prefix": "Bearer" },
      "key_placeholder": "sk-…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://platform.openai.com/docs",
      "color": "#10a37f"
    },
    "google": {
      "name": "Google AI",
      "description": "Gemini models via AI Studio",
      "category": "ai",
      "upstream": "https://generativelanguage.googleapis.com",
      "auth": { "type": "query", "param": "key" },
      "key_placeholder": "AIza…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://ai.google.dev/docs",
      "color": "#4285f4"
    },
    "deepseek": {
      "name": "DeepSeek",
      "description": "DeepSeek Chat and reasoning models",
      "category": "ai",
      "upstream": "https://api.deepseek.com",
      "auth": { "type": "header", "header": "Authorization", "prefix": "Bearer" },
      "key_placeholder": "sk-…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://platform.deepseek.com/api-docs",
      "color": "#5b5de5"
    },
    "groq": {
      "name": "Groq",
      "description": "Fast inference for open models",
      "category": "ai",
      "upstream": "https://api.groq.com/openai/v1",
      "auth": { "type": "header", "header": "Authorization", "prefix": "Bearer" },
      "key_placeholder": "gsk_…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://console.groq.com/docs",
      "color": "#f55036"
    },
    "brave": {
      "name": "Brave Search",
      "description": "Web search API",
      "category": "ai",
      "upstream": "https://api.search.brave.com",
      "auth": { "type": "header", "header": "X-Subscription-Token" },
      "key_placeholder": "BSA…",
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://brave.com/search/api/",
      "color": "#f55036"
    },

    "gmail": {
      "name": "Gmail",
      "description": "Google Gmail API",
      "category": "google",
      "upstream": "https://gmail.googleapis.com",
      "auth": { "type": "oauth2", "provider": "google" },
      "default_levels": { "read": "elevated", "write": "critical" },
      "docs": "https://developers.google.com/gmail/api",
      "color": "#ea4335"
    },
    "gdrive": {
      "name": "Google Drive",
      "description": "Google Drive file management",
      "category": "google",
      "upstream": "https://www.googleapis.com/drive/v3",
      "auth": { "type": "oauth2", "provider": "google" },
      "default_levels": { "read": "elevated", "write": "critical" },
      "docs": "https://developers.google.com/drive/api",
      "color": "#4285f4"
    },
    "gcalendar": {
      "name": "Google Calendar",
      "description": "Google Calendar API",
      "category": "google",
      "upstream": "https://www.googleapis.com/calendar/v3",
      "auth": { "type": "oauth2", "provider": "google" },
      "default_levels": { "read": "standard", "write": "elevated" },
      "docs": "https://developers.google.com/calendar/api",
      "color": "#4285f4"
    },

    "telegram": {
      "name": "Telegram",
      "description": "Telegram Bot API",
      "category": "channel",
      "upstream": "https://api.telegram.org",
      "auth": { "type": "path" },
      "default_levels": { "read": "standard", "write": "standard" },
      "docs": "https://core.telegram.org/bots/api",
      "color": "#26a5e4"
    },

    "github": {
      "name": "GitHub",
      "description": "GitHub REST API",
      "category": "service",
      "upstream": "https://api.github.com",
      "auth": { "type": "header", "header": "Authorization", "prefix": "Bearer" },
      "key_placeholder": "ghp_…",
      "default_levels": { "read": "standard", "write": "elevated" },
      "docs": "https://docs.github.com/en/rest",
      "color": "#e6edf3"
    },
    "twilio": {
      "name": "Twilio",
      "description": "SMS and voice API",
      "category": "service",
      "upstream": "https://api.twilio.com/2010-04-01",
      "auth": { "type": "basic", "username_label": "Account SID" },
      "default_levels": { "read": "standard", "write": "critical" },
      "docs": "https://www.twilio.com/docs/usage/api",
      "color": "#f22f46"
    }
  },

  "categories": {
    "ai": { "name": "AI Providers", "priority": ["anthropic", "openai", "google", "deepseek", "groq", "brave"] },
    "google": { "name": "Google Services", "priority": ["gmail", "gdrive", "gcalendar"] },
    "channel": { "name": "Messaging Channels", "priority": ["telegram"] },
    "service": { "name": "Other Services", "priority": ["github", "twilio"] }
  }
}
